# PipeCraft — https://pipecraft.thecraftlab.dev
# develop → main matches project branching; regenerate with: pnpm workflow:generate
ciProvider: github
mergeStrategy: fast-forward
requireConventionalCommits: true

initialBranch: develop
finalBranch: main

branchFlow:
  - develop
  - main

domains:
  bench:
    description: lmstudio-bench CLI and sweep tooling
    paths:
      - package.json
      - pnpm-lock.yaml
      - tsconfig.json
      - tsup.config.ts
      - vitest.config.ts
      - src/**
      - tests/**
